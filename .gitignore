# ─── Xcode Project (generated by XcodeGen — do not commit) ───────────────────
*.xcodeproj/
!*.xcodeproj/project.xcworkspace/

# ─── Xcode User Data ─────────────────────────────────────────────────────────
xcuserdata/
*.xcuserstate
*.xcuserdatad/

# ─── Xcode Build ─────────────────────────────────────────────────────────────
DerivedData/
build/
*.o
*.d

# ─── Swift Package Manager ───────────────────────────────────────────────────
.build/
.swiftpm/
**/checkouts/
**/artifacts/
Package.resolved

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── API Keys / Secrets ──────────────────────────────────────────────────────
.env
.env.*
*.secret
Secrets.xcconfig
secrets.xcconfig
# Keep xcconfig structure but never commit real keys
# Configurations/*.xcconfig is committed with REPLACE_WITH_* placeholders only

# ─── CocoaPods (not used, but just in case) ──────────────────────────────────
Pods/
Podfile.lock

# ─── Fastlane ────────────────────────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# ─── Archives & Exports ──────────────────────────────────────────────────────
*.ipa
*.dSYM.zip
*.dSYM

# ─── Editor ──────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~

# ─── XcodeGen (regenerate with: xcodegen generate) ───────────────────────────
*.xcodeproj/
*.xcworkspace/

# ─── Xcode Build ─────────────────────────────────────────────────────────────
DerivedData/
xcuserdata/
*.xcuserstate
